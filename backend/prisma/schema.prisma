generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candle {
  id        Int      @id @default(autoincrement())
  broker    String
  symbol    String
  timeframe String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float

  @@unique([broker, symbol, timeframe, time])
  @@index([broker, symbol, timeframe])
  @@map("candles")
}

model Position {
  ticket     Int      @id
  broker     String
  symbol     String
  type       Int
  lots       Float
  openPrice  Float
  sl         Float
  tp         Float
  profit     Float
  swap       Float
  commission Float
  magic      Int
  comment    String
  openTime   DateTime
  updatedAt  DateTime @updatedAt

  @@index([broker])
  @@map("positions")
}

model Trade {
  ticket     Int      @id
  broker     String
  symbol     String
  type       Int
  lots       Float
  openPrice  Float
  closePrice Float
  sl         Float
  tp         Float
  profit     Float
  swap       Float
  commission Float
  magic      Int
  comment    String
  openTime   DateTime
  closeTime  DateTime

  @@index([broker, symbol])
  @@index([closeTime])
  @@map("trades")
}

model Strategy {
  id        Int           @id @default(autoincrement())
  broker    String
  symbol    String
  timeframe String
  config    Json
  active    Boolean       @default(true)
  runs      BacktestRun[]

  @@index([broker, active])
  @@map("strategies")
}

model BacktestRun {
  id          Int             @id @default(autoincrement())
  strategyId  Int
  strategy    Strategy        @relation(fields: [strategyId], references: [id])
  broker      String
  symbol      String
  timeframe   String
  dateFrom    DateTime
  dateTo      DateTime
  configHash  String
  createdAt   DateTime        @default(now())
  setups      BacktestSetup[]

  @@index([strategyId])
  @@map("backtest_runs")
}

model BacktestSetup {
  id              Int             @id @default(autoincrement())
  runId           Int
  run             BacktestRun     @relation(fields: [runId], references: [id])
  direction       String
  activationTime  DateTime
  activationPrice Float
  closeTime       DateTime?
  closePrice      Float?
  levels          Json
  candleCount     Int
  trades          BacktestTrade[]

  @@index([runId])
  @@map("backtest_setups")
}

model BacktestTrade {
  id          Int           @id @default(autoincrement())
  setupId     Int
  setup       BacktestSetup @relation(fields: [setupId], references: [id])
  entryType   String
  entryPrice  Float
  sl          Float
  tp          Float
  entryTime   DateTime
  closeTime   DateTime?
  resultPips  Float?
  resultRR    Float?
  status      String

  @@index([setupId])
  @@map("backtest_trades")
}

model Balance {
  id         Int      @id @default(autoincrement())
  broker     String
  balance    Float
  equity     Float
  profit     Float
  margin     Float
  freeMargin Float
  leverage   Int
  currency   String
  name       String
  number     Int
  timestamp  DateTime @default(now())

  @@index([broker, timestamp])
  @@map("balances")
}
