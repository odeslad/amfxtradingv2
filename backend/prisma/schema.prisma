generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Candle {
  id        Int      @id @default(autoincrement())
  broker    String
  symbol    String
  timeframe String
  time      DateTime
  open      Float
  high      Float
  low       Float
  close     Float

  @@unique([broker, symbol, timeframe, time])
  @@index([broker, symbol, timeframe])
  @@map("candles")
}

model Trade {
  ticket     Int      @id
  broker     String
  symbol     String
  type       Int
  lots       Float
  openPrice  Float
  closePrice Float
  sl         Float
  tp         Float
  profit     Float
  swap       Float
  commission Float
  magic      Int
  comment    String
  openTime   DateTime
  closeTime  DateTime

  @@index([broker, symbol])
  @@index([closeTime])
  @@map("trades")
}

model Strategy {
  id        Int           @id @default(autoincrement())
  broker    String
  symbol    String
  timeframe String
  config    Json
  active    Boolean       @default(true)
  runs      BacktestRun[]

  @@index([broker, active])
  @@map("strategies")
}

model BacktestRun {
  id          Int             @id @default(autoincrement())
  strategyId  Int
  strategy    Strategy        @relation(fields: [strategyId], references: [id])
  broker      String
  symbol      String
  timeframe   String
  dateFrom    DateTime
  dateTo      DateTime
  configHash  String
  createdAt   DateTime        @default(now())
  setups      BacktestSetup[]

  @@index([strategyId])
  @@map("backtest_runs")
}

model BacktestSetup {
  id              Int             @id @default(autoincrement())
  runId           Int
  run             BacktestRun     @relation(fields: [runId], references: [id])
  direction       String
  activationTime  DateTime
  activationPrice Float
  closeTime       DateTime?
  closePrice      Float?
  levels          Json
  candleCount     Int
  weakCandles     DateTime[]
  strongCandles   DateTime[]
  pivots          Json       @default("[]")
  mfePrice        Float?
  mfeTime         DateTime?
  maePrice        Float?
  maeTime         DateTime?
  trades          BacktestTrade[]

  @@index([runId])
  @@map("backtest_setups")
}

model BacktestTrade {
  id          Int           @id @default(autoincrement())
  setupId     Int
  setup       BacktestSetup @relation(fields: [setupId], references: [id])
  entryType   String
  entryPrice  Float
  sl          Float
  tp          Float
  entryTime   DateTime?
  exitTime    DateTime?
  exitPrice   Float?
  resultPips  Float?
  status      String
  reason      String?

  @@index([setupId])
  @@map("backtest_trades")
}

model SettingsMirror {
  id        Int      @id @default(autoincrement())
  broker    String   @unique
  enabled   Boolean  @default(false)
  lotsMode  String   @default("fixed")
  lots      Float    @default(0.01)
  updatedAt DateTime @updatedAt

  @@map("settings_mirror")
}

model SettingsDisplay {
  id             Int      @id @default(autoincrement())
  key            String   @unique @default("global")
  pnlMode        String   @default("net")
  trendlineColor String   @default("#8c8c8c")
  trendlineStyle String   @default("dashed")
  trendlineWidth Int      @default(1)
  updatedAt      DateTime @updatedAt

  @@map("settings_display")
}

model PositionColor {
  id      Int    @id @default(autoincrement())
  broker  String
  ticket  Int
  color   String

  @@unique([broker, ticket])
  @@map("position_colors")
}

model User {
  id                Int               @id @default(autoincrement())
  email             String            @unique
  passwordHash      String
  createdAt         DateTime          @default(now())
  chartIndicators   ChartIndicators?
  drawings          Drawing[]

  @@map("users")
}

model Drawing {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id])
  broker    String
  symbol    String
  timeframe String
  items     Json     @default("[]")
  updatedAt DateTime @updatedAt

  @@unique([userId, broker, symbol, timeframe])
  @@index([userId, broker, symbol, timeframe])
  @@map("drawings")
}

model ChartIndicators {
  id     Int  @id @default(autoincrement())
  userId Int  @unique
  user   User @relation(fields: [userId], references: [id])
  emas   Json @default("[]")

  @@map("chart_indicators")
}

model Balance {
  id         Int      @id @default(autoincrement())
  broker     String
  balance    Float
  equity     Float
  profit     Float
  margin     Float
  freeMargin Float
  leverage   Int
  currency   String
  name       String
  number     Int
  timestamp  DateTime @default(now())

  @@index([broker, timestamp])
  @@map("balances")
}
